<div style="background-color: white !important; color: black !important; padding: 0; margin: 0; font-family: Arial, sans-serif; width: 100%; min-height: 300px;">
  
  <div style="background-color: #000; color: #FFD700; text-align: center; font-size: 28px; font-weight: bold; padding: 15px; border: 1px solid #000;">
    CREDITO INSS
  </div>

  <table style="width: 100%; border-collapse: collapse; background-color: white !important; color: black !important;">
    <thead>
      <tr style="background-color: #f2f2f2;">
        <th style="border: 1px solid #ccc; padding: 10px; text-align: left; color: #333; font-size: 14px;">SITUACAO</th>
        <th style="border: 1px solid #ccc; padding: 10px; text-align: left; color: #333; font-size: 14px;">DESBLOQUEOU</th>
        <th style="border: 1px solid #ccc; padding: 10px; text-align: left; color: #333; font-size: 14px;">QTDE</th>
      </tr>
    </thead>
    <tbody>
      {{#each data}}
      <tr>
        <td style="border-left: 1px solid #ccc; border-bottom: 1px solid #eee; padding: 15px 10px; font-size: 45px; font-weight: bold; color: black !important;">
          {{SITUACAO}}
        </td>
        <td style="border-left: 1px solid #ccc; border-bottom: 1px solid #eee; padding: 15px 10px; font-size: 45px; font-weight: bold; color: black !important;">
          {{DESBLOQUEOU}}
        </td>
        <td style="border-left: 1px solid #ccc; border-right: 1px solid #ccc; border-bottom: 1px solid #eee; padding: 15px 10px; font-size: 45px; font-weight: bold; color: black !important;">
          {{QTDE}}
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
